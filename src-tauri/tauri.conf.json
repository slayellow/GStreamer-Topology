{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GStreamer To Topology",
  "version": "0.1.0",
  "identifier": "com.codex.gstreamer-to-topology",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GStreamer To Topology",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
