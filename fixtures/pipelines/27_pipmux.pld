h265parse config-interval=-1 ! video/x-h265,stream-format=byte-stream,alignment=au ! 
identity name=eoklvmeta ! queue ! tsrec_eo.video

appsrc name=eoklvsrc is-live=true format=time do-timestamp=true caps="meta/x-klv,parsed=true" ! queue ! tsrec_eo.subtitle_0

splitmuxsink name=tsrec_eo max-size-time=30000000000 muxer=mpegtsmux location=/tmp/EO_IN_%d.ts

eo_sr_in.src_0 ! eo_sr_out.

eo_sr_in.src_1 ! queue ! qtivtransform name=eo_srcrop1 crop=<320,180,640,360> ! video/x-raw(memory:GBM),format=NV12,width=640,height=360 !
qtimlvconverter ! neural-network/tensors,type=FLOAT32 ! queue leaky=1 max-size-buffers=2 ! 
qtimlsnpe delegate=dsp model=/data/solvit/sr/SVFocusSRNet_EO_640x360_x2_v2.dlc layers=<final_act> ! 
qtimlvsuperresolution module=srnet-float constants="output,q-offsets=<0.0>,q-scales=<1.0>;" ! 
video/x-raw(memory:GBM),format=RGBA,width=1280,height=720 !
qtivtransform ! eo_sr_out.

eo_sr_in.src_2 ! queue ! qtivtransform name=eo_srcrop2 crop=<480,270,320,180> ! video/x-raw(memory:GBM),format=NV12,width=320,height=180 !
qtimlvconverter ! neural-network/tensors,type=FLOAT32 ! queue leaky=1 max-size-buffers=2 ! 
