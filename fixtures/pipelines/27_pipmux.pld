neural-network/tensors,type=FLOAT32 ! 
qtimlvsuperresolution module=srnet-float constants="output,q-offsets=<0.0>,q-scales=<1.0>;" ! 
video/x-raw(memory:GBM),format=RGBA,width=1280,height=720 !
qtivtransform ! eo_sr_out.

funnel forward-sticky-events=0 name=eo_sr_out !
identity name=eo_sr_merge_guard !
tee name=eo_det_hd ! 
queue ! qtivtransform ! qtioverlay name=eo_hud engine=2 ! queue ! 
qtic2venc name=eo_venc control-rate=2 idr-interval=60 target-bitrate={EO_BITRATE} ! 
{VENC_CODEC}parse config-interval=-1 ! tee name=eoenc ! rtp{VENC_CODEC}pay mtu=1350 ! queue ! appsink name=eotxstm emit-signals=true 

eoenc. ! queue name=EO_OUT_SRC ! splitmuxsink name=EO_OUT_MUX max-size-time=30000000000 muxer=matroskamux location=/tmp/EO_OUT_%d.mkv

eo_det_hd. ! queue ! qtivtransform ! video/x-raw,format=RGBA,width=1280,height=736 !
tee name=eorgb ! qtimetamux name=eometamux mode=2 latency=500000000 ! video/x-raw,format=RGBA,width=1280,height=736 ! detections.

