qtiqmmfsrc camera=0 name=eocam0 ! video/x-raw(memory:GBM),format=NV12,framerate=30/1,width=1920,height=1080 ! 
tee name=eoraw ! queue ! qtimetamux name=eismux mode=1 latency=10000000 scale_opt=FALSE ! 
qtivtransform name=eocrop0 background=0 eis-enabled=0 crop=<0,0,1920,1080> eis-mv-num-th=2731 eis-range={EIS_RANGE} lpf-alpha=0.95 ! 
video/x-raw(memory:GBM),format=NV12,width=1280,height=720 ! 
qtimlvconverter ! neural-network/tensors,type=FLOAT32 ! queue leaky=1 max-size-buffers=2 ! 
qtimlsnpe delegate=dsp model=/data/solvit/sr/SVFocusDenoiseNet_1280x720_v2.dlc layers=<n4_5> ! 
qtimlvsuperresolution module=srnet-float constants="output,q-offsets=<0.0>,q-scales=<1.0>;" ! 
video/x-raw(memory:GBM),format=RGBA,width=1280,height=720 ! 
qtivtransform ! video/x-raw(memory:GBM),format=NV12,width=1280,height=720 ! 
output-selector name=eo_sr_in active-pad=eo_sr_in.src_0  

eoraw. ! qtivtransform name=optsize crop=<704,284,512,512> ! video/x-raw(memory:GBM),format=NV12,width=512,height=512 ! 
queue ! qticvoptclflow ! cv/x-optical-flow ! eismux.

